{
  "name": "piclaw-addons",
  "version": "2.0.0",
  "description": "Community add-ons for piclaw — extensions, skills, and widgets",
  "keywords": [
    "extensions",
    "pi-package",
    "piclaw",
    "skills"
  ],
  "type": "module",
  "scripts": {
    "sync:catalog": "bun scripts/sync-catalog.ts --write",
    "check:catalog": "bun scripts/sync-catalog.ts --check"
  },
  "homepage": "https://github.com/rcarmo/piclaw-addons",
  "bugs": {
    "url": "https://github.com/rcarmo/piclaw-addons/issues"
  },
  "pi": {
    "extensions": [
      "addons/autoresearch/index.ts",
      "addons/code-validator/index.ts",
      "addons/delegate/index.ts",
      "addons/dev-tools/index.ts",
      "addons/drawio-editor/index.ts",
      "addons/eml-viewer/index.ts",
      "addons/kanban-board-widget/index.ts"
    ],
    "skills": [
      "addons/autoresearch/skills",
      "addons/delegate/skills"
    ]
  },
  "agents": {
    "skills": [
      {
        "name": "autoresearch-create",
        "path": "./addons/autoresearch/skills/autoresearch-create"
      },
      {
        "name": "delegate",
        "path": "./addons/delegate/skills/delegate"
      }
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rcarmo/piclaw-addons.git"
  },
  "files": [
    "LICENSE",
    "README.md",
    "addons",
    "catalog.json"
  ]
}
