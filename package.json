{
  "name": "@rcarmo/piclaw-addons",
  "version": "2.0.1",
  "description": "Community add-ons for piclaw — extensions, skills, and widgets",
  "keywords": [
    "extensions",
    "pi-package",
    "piclaw",
    "skills"
  ],
  "type": "module",
  "scripts": {
    "sync:catalog": "bun scripts/sync-catalog.ts --write",
    "check:catalog": "bun scripts/sync-catalog.ts --check"
  },
  "homepage": "https://github.com/rcarmo/piclaw-addons",
  "bugs": {
    "url": "https://github.com/rcarmo/piclaw-addons/issues"
  },
  "pi": {
    "extensions": [
      "addons/ast-grep-tool/index.ts",
      "addons/autoresearch/index.ts",
      "addons/cheapskate/index.ts",
      "addons/code-validator/index.ts",
      "addons/delegate/index.ts",
      "addons/dev-tools/index.ts",
      "addons/drawio-editor/index.ts",
      "addons/eml-viewer/index.ts",
      "addons/git-query-tools/index.ts",
      "addons/imap/index.ts",
      "addons/kanban-board-widget/index.ts",
      "addons/observability/index.ts",
      "addons/portainer/index.ts",
      "addons/proxmox/index.ts",
      "addons/sample-addon/index.ts",
      "addons/voice-pipeline/index.ts"
    ],
    "runtime": {
      "entries": [
        "addons/autoresearch/runtime.ts"
      ]
    },
    "skills": [
      "addons/autoresearch/skills",
      "addons/delegate/skills",
      "addons/settings-dialog-screenshot/skills"
    ]
  },
  "agents": {
    "skills": [
      {
        "name": "autoresearch-create",
        "path": "./addons/autoresearch/skills/autoresearch-create"
      },
      {
        "name": "delegate",
        "path": "./addons/delegate/skills/delegate"
      },
      {
        "name": "settings-dialog-screenshot",
        "path": "./addons/settings-dialog-screenshot/skills/settings-dialog-screenshot"
      }
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rcarmo/piclaw-addons.git"
  },
  "files": [
    "LICENSE",
    "README.md",
    "addons",
    "catalog.json"
  ],
  "devDependencies": {
    "bun-types": "^1.3.13",
    "marked": "^18.0.2"
  }
}
