{
  "name": "@rcarmo/piclaw-addon-imap",
  "version": "0.1.0",
  "description": "IMAP email management tool \u2014 search/fetch, move/copy, flag, create drafts, file messages, and STARTTLS support",
  "type": "module",
  "main": "index.ts",
  "piclaw": {
    "type": "extension",
    "compatibleVersions": ">=2.0.0",
    "tags": [
      "imap",
      "email",
      "mail",
      "productivity"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "license": "MIT",
  "keywords": [
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "index.ts"
    ]
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  }
}