{
  "name": "@rcarmo/piclaw-addon-codex-conversion",
  "version": "0.1.1",
  "description": "Codex-style prompt and tool adapter for OpenAI/Codex-like models in Piclaw",
  "type": "module",
  "main": "src/index.ts",
  "piclaw": {
    "type": "extension",
    "compatibleVersions": ">=1.8.0",
    "tags": [
      "codex",
      "tools",
      "openai",
      "adapter",
      "prompting"
    ]
  },
  "license": "MIT",
  "keywords": [
    "pi-package",
    "piclaw-addon",
    "codex",
    "openai",
    "adapter"
  ],
  "pi": {
    "extensions": [
      "src/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "dependencies": {
    "node-pty": "^1.1.0",
    "partial-json": "^0.1.7",
    "tree-sitter-bash": "^0.25.1",
    "web-tree-sitter": "^0.26.7"
  },
  "homepage": "https://rcarmo.github.io/piclaw-addons/addons/codex-conversion/",
  "repository": {
    "type": "git",
    "url": "https://github.com/rcarmo/piclaw-addons.git",
    "directory": "addons/codex-conversion"
  }
}
